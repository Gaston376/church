{
  "name": "massajja-tower-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create subscribers",
    "db:migrate": "wrangler d1 execute subscribers --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute subscribers --file=./schema.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.78.0"
  }
}
